# MongoDB Atlas (required) — replace with your cluster connection string.
# Do NOT use mongodb://localhost:27017 unless MongoDB is installed and running locally.
# Include database name and standard Atlas options in the URI.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/harvestiq?retryWrites=true&w=majority
MONGODB_DB_NAME=harvestiq

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Cookie settings (use false for local HTTP dev)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# App
ENVIRONMENT=development

# Weather providers
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
OPENWEATHER_API_KEY=
WEATHER_CACHE_TTL_MINUTES=30

# Day 4 — Knowledge base, disease vision
CHROMA_PERSIST_DIR=data/chroma
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_TEXT_MODEL=gemini-2.0-flash
DISEASE_CONFIDENCE_THRESHOLD=0.70
DISEASE_UPLOAD_DIR=data/uploads/disease

# SOS / Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
EXTERNAL_CALLBACK_URL=https://harvestiq-engine.onrender.com
DEMO_ENABLED=true

# Web Push (required for push notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@harvestiq.app
